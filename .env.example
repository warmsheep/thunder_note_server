# Thunder Note Server 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# 重要：不要将 .env 提交到版本库！

# 数据库连接（使用 NOTE_ 前缀避免与其他项目冲突）
NOTE_DB_HOST=172.17.0.1
NOTE_DB_PORT=15432
NOTE_DB_PASSWORD=postgres
NOTE_DB_NAME=thunder_note
NOTE_DB_USERNAME=postgres

# Redis 连接
NOTE_REDIS_HOST=localhost
NOTE_REDIS_PORT=6379
NOTE_REDIS_DATABASE=0

# JWT 密钥（生产环境必须设置，使用随机密钥）
# 生成方式：openssl rand -base64 32
NOTE_JWT_SECRET=thunder-note-super-secure-jwt-secret-key-please-change-now-2026

# MinIO 对象存储
NOTE_MINIO_ENDPOINT=http://localhost:9000
NOTE_MINIO_ACCESS_KEY=minioadmin
NOTE_MINIO_SECRET_KEY=minioadmin
NOTE_MINIO_BUCKET=thunder-note

# CORS 允许来源（多个用逗号分隔）
NOTE_CORS_ORIGINS=http://localhost:*

# 日志级别
NOTE_LOG_LEVEL=debug

# 服务器端口（可选，默认 8080）
# SERVER_PORT=8080
