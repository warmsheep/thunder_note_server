# Docker Compose 环境变量模板
# 复制为 .env 后再执行 docker compose up -d --build

# --- server ---
SERVER_PORT=8080
NOTE_JWT_SECRET=replace-with-a-random-secret
NOTE_CORS_ORIGINS=http://localhost:*
NOTE_LOG_LEVEL=debug
NOTE_REDIS_DATABASE=0

# --- postgres ---
POSTGRES_DB=thunder_note
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=15432

# --- redis ---
REDIS_HOST_PORT=6379

# --- minio ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=thunder-note
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
